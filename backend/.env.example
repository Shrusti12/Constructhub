DATABASE_URL=postgresql+psycopg://postgres:1234@localhost:5432/constructhub
CORS_ORIGINS=http://localhost:5173
JWT_SECRET_KEY=dev-only-change-me
AUTO_CREATE_DB=true

# AI
# offline: local demo images
# openai: real images + dynamic description (requires an API key)
AI_PROVIDER=offline
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_CALL_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
